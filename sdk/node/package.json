{
  "name": "smolmachines",
  "version": "1.5.0",
  "description": "Embed isolated microVM sandboxes directly in your code — no server to run.",
  "license": "Apache-2.0",
  "author": "smol-machines",
  "homepage": "https://github.com/smol-machines/smol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smol-machines/smol.git",
    "directory": "sdk/node"
  },
  "bugs": {
    "url": "https://github.com/smol-machines/smol/issues"
  },
  "keywords": [
    "sandbox",
    "microvm",
    "isolation",
    "vm",
    "smolvm",
    "smolfleet"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "native",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "name": "smol",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "build:native": "napi build --platform --release --js binding.js --dts binding.d.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts && npm run bundle:native",
    "bundle:native": "cp binding.js binding.d.ts *.node dist/ 2>/dev/null || true",
    "test:e2e": "napi build --platform --js binding.js --dts binding.d.ts && tsx test/e2e.ts",
    "gen:openapi": "bash scripts/gen-openapi.sh",
    "test:cloud": "tsx test/cloud-mock.ts",
    "test:unit": "tsx test/unit.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^20.11.0",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
